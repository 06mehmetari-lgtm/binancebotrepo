# .env.example — şablon, güvenli paylaşılabilir

# ═══════════════════════════════════════
# Binance
# ═══════════════════════════════════════
BINANCE_API_KEY=
BINANCE_SECRET=

# AUTO = top USDM perpetuals by 24h volume (see TOP_SYMBOLS)
TRADING_SYMBOLS=AUTO
TOP_SYMBOLS=500
AGENT_BATCH_SIZE=120
AGENT_CONCURRENCY=40
DRY_RUN=true
# Live Binance orders require BOTH flags (shadow must approve first):
LIVE_TRADING_CONFIRMED=false

# Persist closed trades to Postgres (audit + promotion proof)
TRADES_POSTGRES_WRITE=true

# Signal ensemble (agent + NEAT + PPO RL)
ENSEMBLE_WEIGHT_AGENT=0.55
ENSEMBLE_WEIGHT_NEAT=0.25
ENSEMBLE_WEIGHT_RL=0.20
SIGNAL_MIN_CONFIDENCE=0.60

# Persist features to TimescaleDB for NEAT/RL/backtest history
FEATURES_TIMESCALE_WRITE=true

# Sürekli backtest (7/24 parça parça tüm evren)
BACKTEST_TOTAL_SYMBOLS=500
BACKTEST_CHUNK_SIZE=20
BACKTEST_DAYS=365
BACKTEST_CHUNK_PAUSE_SEC=3

# Continual learning engine (2s scan + feature pub/sub)
LEARNING_SCAN_SEC=2
LEARNING_SCAN_BATCH=100
LEARNING_CONCURRENCY=80
LEARNING_PROFILE_EVERY_N=30
LEARNING_LLM_EVERY_N=90
LEARNING_FAST_TRACK=true
LEARNING_OPEN_POSITION_SEC=0.5
# ═══════════════════════════════════════
# LLM — çoklu anahtar + sağlayıcı zinciri (rate-limit → sıradaki)
# LLM_KEY_SLOTS: GROQ_API_KEY_1 .. _N (varsayılan 32)
# LLM_PROVIDER_ORDER: virgülle ayrılmış öncelik
# ═══════════════════════════════════════
LLM_KEY_SLOTS=32
LLM_PROVIDER_ORDER=groq,cerebras,sambanova,openrouter,mistral,together,fireworks,cohere,deepseek,huggingface,google,perplexity,zai,anthropic,ollama

GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
GROQ_API_KEY_9=
GROQ_API_KEY_10=
GROQ_API_KEY_11=
GROQ_API_KEY_12=
GROQ_API_KEY_13=
GROQ_API_KEY_14=
GROQ_API_KEY_15=
GROQ_API_KEY_16=
GROQ_API_KEY_17=
GROQ_API_KEY_18=
GROQ_API_KEY_19=
GROQ_API_KEY_20=
GROQ_API_KEY_21=
GROQ_API_KEY_22=
GROQ_API_KEY_23=
GROQ_API_KEY_24=
GROQ_API_KEY_25=
GROQ_API_KEY_26=
GROQ_API_KEY_27=
GROQ_API_KEY_28=
GROQ_API_KEY_29=
GROQ_API_KEY_30=
GROQ_API_KEY_31=
GROQ_API_KEY_32=
GROQ_DEBATE_MODEL=llama-3.3-70b-versatile
GROQ_LEARN_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_SLOTS=20

# --- Groq model havuzları (tek API key ile hepsi; isimler Groq API'ye gider) ---
GROQ_FAST_MODELS=llama-3.1-8b-instant
GROQ_FAST_MODELS_2=gemma2-9b-it
GROQ_MAIN_MODELS=llama-3.3-70b-versatile
GROQ_MAIN_MODELS_2=llama-3.1-8b-instant
GROQ_REASON_MODELS=deepseek-r1-distill-llama-70b
GROQ_REASON_MODELS_2=qwen-qwq-32b
GROQ_RISK_MODELS=mixtral-8x7b-32768
GROQ_LEARNING_MODELS=gemma2-9b-it
GROQ_LEARNING_MODELS_2=llama-3.1-8b-instant
GROQ_FINAL_MODEL=llama-3.3-70b-versatile
GROQ_FINAL_MODEL_2=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# AI orchestration (swarm / consensus)
AI_MINIMUM_MODEL_VOTE=3
AI_REQUIRED_CONFIDENCE=0.72
AI_MAX_PARALLEL_REQUEST=12
AI_ENABLE_DEBATE=true
AI_ENABLE_SWARM=true
AI_ENABLE_FALLBACK=true
AI_ENABLE_AUTO_RETRY=true
AI_REQUEST_TIMEOUT=45
AI_MAX_RETRY=5

# Cerebras — ana anahtar yok; _1 .. _N (Groq ile aynı rotasyon)
CEREBRAS_API_KEY_1=
CEREBRAS_API_KEY_2=
CEREBRAS_MODEL=gpt-oss-120b

SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.1-8B-Instruct

OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-2-9b-it:free
OPENROUTER_REFERER=https://prometheus.local

MISTRAL_API_KEY=
MISTRAL_MODEL=open-mistral-nemo

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct

COHERE_API_KEY=
COHERE_MODEL=command-r7b-12-2024

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

HUGGINGFACE_API_KEY=
HF_API_KEY=
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

GOOGLE_AI_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash

PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4-flash

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OLLAMA_URL=http://ollama:11434
# CPU VPS: llama3.2:3b daha hızlı; GPU varsa llama3.1:8b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=240
# PC kapalı VPS (limit beklemeli): LLM_VPS_MODE=true + GOOGLE_AI_API_KEY
# bash scripts/setup-vps-llm-wait-mode.sh
LLM_VPS_MODE=false
LLM_QUOTA_WAIT_SEC=45

# VPS Cloudflare 1010 — Groq/Cerebras için AŞAĞIDAKİLERDEN BİRİ ŞART:
# (1) Residential proxy:
# HTTPS_PROXY=http://user:pass@proxy-host:port
# (2) Ev PC relay — scripts/run-llm-relay-at-home.md
# LLM_RELAY_URL=https://xxxx.trycloudflare.com
# LLM_RELAY_SECRET=uzun-rastgele-sifre
# Sonra: bash scripts/enable-groq-cerebras.sh
#
# Çoklu relay/proxy (biri düşerse sıradaki — max 64 slot):
# LLM_RELAY_URL_1=https://tunnel1.trycloudflare.com
# LLM_RELAY_URL_2=https://tunnel2.trycloudflare.com
# PROXY_URL_1=socks5://127.0.0.1:1080
# PROXY_LIST=http://p1:8080,socks5://p2:1080
# PROXY_POOL_SLOTS=64
#
# Proxy/relay yoksa Ollama:
LLM_OLLAMA_ONLY=true
LLM_CLOUD_BLOCKED=true
LLM_PROVIDER_ORDER=ollama

# AI Position Guard (saniye bazlı açık pozisyon izleme)
POSITION_GUARD_SEC=1.0
GUARD_MAX_LOSS_PCT=1.5
GUARD_EMERGENCY_LOSS_PCT=2.5
GUARD_ACTION_COOLDOWN=30

# Shadow: tek sembol = tek paper pozisyon (A/B/C mükerrer açmasın)
SHADOW_OPEN_IDS=SHADOW_A
SHADOW_ONE_PER_SYMBOL=true

# ═══════════════════════════════════════
# Veritabanları
# ═══════════════════════════════════════
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=

TIMESCALE_USER=tsuser
TIMESCALE_PASSWORD=

REDIS_PASSWORD=

# ═══════════════════════════════════════
# Monitoring
# ═══════════════════════════════════════
GRAFANA_PASSWORD=

# ═══════════════════════════════════════
# Ücretsiz API'ler
# ═══════════════════════════════════════
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PrometheusTrader/1.0

CRYPTOPANIC_KEY=
FRED_API_KEY=
ETHERSCAN_KEY=
