# .env.example — şablon, güvenli paylaşılabilir

# ═══════════════════════════════════════
# Binance
# ═══════════════════════════════════════
BINANCE_API_KEY=
BINANCE_SECRET=

# AUTO = top USDM perpetuals by 24h volume (see TOP_SYMBOLS)
TRADING_SYMBOLS=AUTO
TOP_SYMBOLS=500
AGENT_BATCH_SIZE=120
AGENT_CONCURRENCY=40
DRY_RUN=true

# ═══════════════════════════════════════
# Veritabanları
# ═══════════════════════════════════════
POSTGRES_USER=prometheus
POSTGRES_PASSWORD=

TIMESCALE_USER=tsuser
TIMESCALE_PASSWORD=

REDIS_PASSWORD=

# ═══════════════════════════════════════
# Monitoring
# ═══════════════════════════════════════
GRAFANA_PASSWORD=

# ═══════════════════════════════════════
# Ücretsiz API'ler
# ═══════════════════════════════════════
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PrometheusTrader/1.0

CRYPTOPANIC_KEY=
FRED_API_KEY=
ETHERSCAN_KEY=
