# LLM API keys — docker-compose environment list (host .env → ${VAR})
# Anahtar: GROQ_API_KEY_1..N (GROQ_API_KEY boşsa _1 yedek)
      - GROQ_API_KEY=${GROQ_API_KEY:-${GROQ_API_KEY_1:-}}
      - GROQ_API_KEY_1=${GROQ_API_KEY_1:-}
      - GROQ_API_KEY_2=${GROQ_API_KEY_2:-}
      - GROQ_API_KEY_3=${GROQ_API_KEY_3:-}
      - GROQ_API_KEY_4=${GROQ_API_KEY_4:-}
      - GROQ_API_KEY_5=${GROQ_API_KEY_5:-}
      - GROQ_API_KEY_6=${GROQ_API_KEY_6:-}
      - GROQ_API_KEY_7=${GROQ_API_KEY_7:-}
      - GROQ_API_KEY_8=${GROQ_API_KEY_8:-}
      - GROQ_API_KEY_9=${GROQ_API_KEY_9:-}
      - GROQ_API_KEY_10=${GROQ_API_KEY_10:-}
      - GROQ_API_KEY_11=${GROQ_API_KEY_11:-}
      - GROQ_API_KEY_12=${GROQ_API_KEY_12:-}
      - CEREBRAS_API_KEY_1=${CEREBRAS_API_KEY_1:-}
      - CEREBRAS_API_KEY_2=${CEREBRAS_API_KEY_2:-}
      - CEREBRAS_MODEL=${CEREBRAS_MODEL:-llama3.1-8b}
      - SAMBANOVA_API_KEY=${SAMBANOVA_API_KEY:-}
      - OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}
      - MISTRAL_API_KEY=${MISTRAL_API_KEY:-}
      - TOGETHER_API_KEY=${TOGETHER_API_KEY:-}
      - FIREWORKS_API_KEY=${FIREWORKS_API_KEY:-}
      - COHERE_API_KEY=${COHERE_API_KEY:-}
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY:-}
      - HUGGINGFACE_API_KEY=${HUGGINGFACE_API_KEY:-}
      - HF_API_KEY=${HF_API_KEY:-}
      - GOOGLE_AI_API_KEY=${GOOGLE_AI_API_KEY:-}
      - GEMINI_API_KEY=${GEMINI_API_KEY:-}
      - PERPLEXITY_API_KEY=${PERPLEXITY_API_KEY:-}
      - ZAI_API_KEY=${ZAI_API_KEY:-}
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - LLM_KEY_SLOTS=${LLM_KEY_SLOTS:-32}
      - LLM_PROVIDER_ORDER=${LLM_PROVIDER_ORDER:-groq,cerebras,sambanova,openrouter,ollama}
      - GROQ_LEARN_MODEL=${GROQ_LEARN_MODEL:-llama-3.1-70b-versatile}
      - GROQ_DEBATE_MODEL=${GROQ_DEBATE_MODEL:-llama-3.1-70b-versatile}
      - GROQ_FAST_MODELS=${GROQ_FAST_MODELS:-}
      - GROQ_MAIN_MODELS=${GROQ_MAIN_MODELS:-}
      - GROQ_LEARNING_MODELS=${GROQ_LEARNING_MODELS:-}
      - GROQ_FINAL_MODEL=${GROQ_FINAL_MODEL:-}
      - GROQ_FALLBACK_MODEL=${GROQ_FALLBACK_MODEL:-}
      - AI_ENABLE_SWARM=${AI_ENABLE_SWARM:-true}
      - AI_MINIMUM_MODEL_VOTE=${AI_MINIMUM_MODEL_VOTE:-3}
      - AI_REQUIRED_CONFIDENCE=${AI_REQUIRED_CONFIDENCE:-0.72}
      - AI_MAX_PARALLEL_REQUEST=${AI_MAX_PARALLEL_REQUEST:-12}
