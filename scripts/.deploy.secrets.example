# Prometheus VPS deploy gizli bilgileri
# Kopyala: copy scripts\.deploy.secrets.example scripts\.deploy.secrets
# ASLA git'e commit etme!

VPS_HOST=194.163.181.39
VPS_USER=root
VPS_PASS=BURAYA_SSH_SIFRESI

# OpenRouter (Groq/Cerebras VPS'te 403 — OpenRouter birincil)
OPENROUTER_API_KEY=sk-or-v1-BURAYA_ANAHTAR

# Sunucudaki proje dizini
VPS_PROJECT_DIR=/root/prometheus

# full = tüm servisler build (30-45 dk) | quick = sadece pipeline+dashboard (10-15 dk)
DEPLOY_MODE=full

# 1 = docker build --no-cache (yavaş, temiz build)
BUILD_NO_CACHE=0
